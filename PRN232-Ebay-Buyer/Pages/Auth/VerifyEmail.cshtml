@page
@model PRN232_Ebay_Buyer.Pages.Auth.VerifyEmailModel
@{
    ViewData["Title"] = "Verify Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4 text-center">
                    @if (Model.IsLoading)
                    {
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p>Verifying your email...</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            @if (Model.IsSuccess)
                            {
                                <div class="text-success">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64"
                                         fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                                    </svg>
                                </div>
                            }
                            else
                            {
                                <div class="text-danger">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64"
                                         fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z" />
                                    </svg>
                                </div>
                            }
                        </div>

                        <h4 class="card-title mb-3">@Model.Title</h4>
                        <p class="card-text">@Model.Message</p>

                        @if (Model.IsSuccess)
                        {
                            <a asp-page="/Auth/Login" class="btn btn-success mt-2">
                                Go to Login
                            </a>
                        }
                        else
                        {
                            <a asp-page="/Auth/Register" class="btn btn-outline-secondary mt-2">
                                Back to Register
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
