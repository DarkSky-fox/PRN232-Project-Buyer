@page "{id:int}"
@model PRN232_Ebay_Buyer.Pages.ProductDetailModel
@{
    ViewData["Title"] = Model.Product?.Title ?? "Product Detail";
}

<style>
    .detail-page { max-width: 1400px; margin: 0 auto; }

    /* ── Breadcrumb ── */
    .breadcrumb-nav {
        padding: 12px 0;
        margin-bottom: 24px;
    }
    .breadcrumb-nav a {
        color: #6c757d;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }
    .breadcrumb-nav a:hover { color: #e94560; }
    .breadcrumb-nav .separator { color: #dee2e6; margin: 0 8px; }
    .breadcrumb-nav .current { color: #1a1a2e; font-weight: 600; font-size: 0.9rem; }

    /* ── Product Main Section ── */
    .product-main {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 20px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
        overflow: hidden;
        margin-bottom: 32px;
    }
    .product-main-inner { padding: 32px; }

    /* ── Image Gallery ── */
    .gallery-main {
        border-radius: 12px;
        overflow: hidden;
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        position: relative;
        width: 100%;
        padding-top: 75%;
    }
    .gallery-main img {
        position: absolute; top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }
    .gallery-main:hover img { transform: scale(1.03); }
    .gallery-main .placeholder-icon {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        font-size: 5rem; color: #dee2e6;
    }
    .gallery-thumbs {
        display: flex; gap: 8px;
        margin-top: 12px; overflow-x: auto;
        padding-bottom: 4px;
    }
    .gallery-thumbs img {
        width: 72px; height: 72px;
        object-fit: cover; border-radius: 8px;
        border: 2px solid #e8ecf1;
        cursor: pointer; transition: all 0.2s;
        flex-shrink: 0;
    }
    .gallery-thumbs img:hover,
    .gallery-thumbs img.active {
        border-color: #e94560;
        box-shadow: 0 2px 8px rgba(233,69,96,0.2);
    }

    /* ── Product Info ── */
    .product-info { padding-left: 16px; }
    .product-category-badge {
        display: inline-block;
        background: #fff0f3; color: #e94560;
        padding: 4px 14px; border-radius: 20px;
        font-size: 0.8rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px;
        margin-bottom: 12px;
    }
    .product-detail-title {
        font-size: 1.8rem; font-weight: 700;
        color: #1a1a2e; line-height: 1.3;
        margin-bottom: 16px;
    }
    .rating-summary {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 20px;
    }
    .stars { color: #f39c12; font-size: 1.1rem; letter-spacing: 2px; }
    .rating-text { color: #6c757d; font-size: 0.9rem; }
    .rating-text strong { color: #1a1a2e; }

    .price-section {
        background: linear-gradient(135deg, #fff5f7, #fef0f3);
        border-radius: 12px; padding: 20px 24px;
        margin-bottom: 24px; border: 1px solid #fde2e7;
    }
    .price-label { font-size: 0.85rem; color: #6c757d; margin-bottom: 4px; }
    .price-value {
        font-size: 2.2rem; font-weight: 800; color: #e94560;
    }
    .auction-badge-detail {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #f39c12, #e67e22);
        color: white; padding: 6px 16px; border-radius: 20px;
        font-size: 0.85rem; font-weight: 600;
        margin-top: 8px;
    }
    .auction-badge-detail .timer-icon { font-size: 1rem; }

    .stock-info {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 20px; font-size: 0.9rem;
    }
    .stock-badge {
        padding: 4px 12px; border-radius: 20px;
        font-weight: 600; font-size: 0.8rem;
    }
    .stock-badge.in-stock { background: #d4edda; color: #155724; }
    .stock-badge.low-stock { background: #fff3cd; color: #856404; }
    .stock-badge.out-of-stock { background: #f8d7da; color: #721c24; }

    .product-description-section { margin-bottom: 24px; }
    .product-description-section h5 {
        font-weight: 700; color: #1a1a2e;
        margin-bottom: 12px; font-size: 1rem;
    }
    .product-description-text {
        color: #495057; line-height: 1.8;
        font-size: 0.95rem; white-space: pre-line;
    }

    /* ── Seller Card ── */
    .seller-card {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 20px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
        padding: 28px; margin-bottom: 32px;
    }
    .seller-card h4 {
        font-weight: 700; color: #1a1a2e;
        margin-bottom: 20px; font-size: 1.1rem;
        display: flex; align-items: center; gap: 8px;
    }
    .seller-profile {
        display: flex; align-items: center; gap: 16px;
        margin-bottom: 20px;
    }
    .seller-avatar {
        width: 64px; height: 64px;
        border-radius: 50%; object-fit: cover;
        border: 3px solid #e8ecf1;
    }
    .seller-avatar-placeholder {
        width: 64px; height: 64px;
        border-radius: 50%; background: linear-gradient(135deg, #e94560, #c0392b);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: white; font-weight: 700;
    }
    .seller-name {
        font-size: 1.15rem; font-weight: 700; color: #1a1a2e;
    }
    .seller-store { font-size: 0.85rem; color: #6c757d; }
    .seller-stats {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }
    .seller-stat {
        text-align: center; padding: 12px;
        background: #f8f9fa; border-radius: 10px;
    }
    .seller-stat-value {
        font-size: 1.2rem; font-weight: 700; color: #1a1a2e;
    }
    .seller-stat-label {
        font-size: 0.75rem; color: #6c757d; margin-top: 2px;
    }

    /* ── Reviews Section ── */
    .reviews-section {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 20px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
        padding: 28px; margin-bottom: 32px;
    }
    .reviews-section h4 {
        font-weight: 700; color: #1a1a2e;
        margin-bottom: 24px; font-size: 1.1rem;
        display: flex; align-items: center; gap: 8px;
    }
    .review-summary {
        display: flex; align-items: center; gap: 24px;
        padding: 20px 24px; background: #f8f9fa;
        border-radius: 12px; margin-bottom: 24px;
    }
    .review-avg {
        text-align: center; min-width: 100px;
    }
    .review-avg-number {
        font-size: 3rem; font-weight: 800; color: #1a1a2e;
        line-height: 1;
    }
    .review-avg-stars {
        color: #f39c12; font-size: 1.2rem;
        margin-top: 4px;
    }
    .review-avg-count {
        font-size: 0.85rem; color: #6c757d; margin-top: 4px;
    }

    .review-item {
        padding: 20px 0;
        border-bottom: 1px solid #f0f2f5;
    }
    .review-item:last-child { border-bottom: none; }
    .review-header {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 10px;
    }
    .review-avatar {
        width: 40px; height: 40px;
        border-radius: 50%; object-fit: cover;
    }
    .review-avatar-placeholder {
        width: 40px; height: 40px;
        border-radius: 50%; background: #e9ecef;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; color: #6c757d; font-weight: 600;
    }
    .review-author { font-weight: 600; color: #1a1a2e; font-size: 0.95rem; }
    .review-date { font-size: 0.8rem; color: #adb5bd; }
    .review-stars { color: #f39c12; font-size: 0.9rem; margin-bottom: 6px; }
    .review-comment {
        color: #495057; line-height: 1.6; font-size: 0.9rem;
    }

    .no-reviews {
        text-align: center; padding: 40px 20px; color: #6c757d;
    }
    .no-reviews .no-icon { font-size: 3rem; color: #dee2e6; margin-bottom: 12px; }

    /* ── Related Products ── */
    .related-section {
        margin-bottom: 32px;
    }
    .related-section h4 {
        font-weight: 700; color: #1a1a2e;
        margin-bottom: 20px; font-size: 1.1rem;
        display: flex; align-items: center; gap: 8px;
    }
    .related-card {
        background: white; border-radius: 12px;
        overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
        transition: all 0.3s; text-decoration: none; color: inherit;
        display: block; height: 100%;
    }
    .related-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        border-color: #e94560; color: inherit;
    }
    .related-card-img {
        position: relative; width: 100%;
        padding-top: 75%; background: #f8f9fa;
        overflow: hidden;
    }
    .related-card-img img {
        position: absolute; top: 0; left: 0;
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.3s;
    }
    .related-card:hover .related-card-img img { transform: scale(1.05); }
    .related-card-img .r-placeholder {
        position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        font-size: 2.5rem; color: #dee2e6;
    }
    .related-card-body { padding: 14px 16px; }
    .related-card-title {
        font-size: 0.9rem; font-weight: 600; color: #1a1a2e;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
        margin-bottom: 8px; line-height: 1.4;
    }
    .related-card-price {
        font-size: 1.1rem; font-weight: 700; color: #e94560;
    }

    /* ── Error ── */
    .error-page {
        text-align: center; padding: 80px 20px;
    }
    .error-page .error-icon { font-size: 5rem; color: #dee2e6; margin-bottom: 16px; }
    .error-page h3 { color: #495057; margin-bottom: 12px; }
    .error-page p { color: #6c757d; margin-bottom: 24px; }

    /* ── Animations ── */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .product-main, .seller-card, .reviews-section, .related-section {
        animation: fadeIn 0.5s ease forwards;
    }
    .seller-card { animation-delay: 0.1s; }
    .reviews-section { animation-delay: 0.15s; }
    .related-section { animation-delay: 0.2s; }
</style>

<div class="detail-page">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-page">
            <div class="error-icon">😔</div>
            <h3>@Model.ErrorMessage</h3>
            <p>The product you're looking for might have been removed or is unavailable.</p>
            <a asp-page="/Products" class="btn btn-primary px-4 py-2" style="background: linear-gradient(135deg, #e94560, #c0392b); border: none; border-radius: 10px;">
                ← Browse Products
            </a>
        </div>
    }
    else if (Model.Product != null)
    {
        var p = Model.Product;

        <!-- ═══ Breadcrumb ═══ -->
        <div class="breadcrumb-nav">
            <a asp-page="/Index">Home</a>
            <span class="separator">›</span>
            <a asp-page="/Products">Products</a>
            @if (!string.IsNullOrEmpty(p.CategoryName))
            {
                <span class="separator">›</span>
                <a asp-page="/Products" asp-route-CategoryId="@p.CategoryId">@p.CategoryName</a>
            }
            <span class="separator">›</span>
            <span class="current">@(p.Title?.Length > 40 ? p.Title.Substring(0, 40) + "..." : p.Title)</span>
        </div>

        <!-- ═══ Product Main ═══ -->
        <div class="product-main">
            <div class="product-main-inner">
                <div class="row">
                    <!-- Image Gallery -->
                    <div class="col-lg-6">
                        <div class="gallery-main" id="mainImage">
                            @if (!string.IsNullOrEmpty(p.Images))
                            {
                                var images = p.Images.Split(',').Select(i => i.Trim()).Where(i => !string.IsNullOrEmpty(i)).ToList();
                                <img src="@images.First()" alt="@p.Title" id="mainImgTag"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                                <div class="placeholder-icon" style="display:none;">📦</div>
                            }
                            else
                            {
                                <div class="placeholder-icon">📦</div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(p.Images))
                        {
                            var images = p.Images.Split(',').Select(i => i.Trim()).Where(i => !string.IsNullOrEmpty(i)).ToList();
                            @if (images.Count > 1)
                            {
                                <div class="gallery-thumbs">
                                    @foreach (var img in images)
                                    {
                                        <img src="@img" alt="Thumbnail"
                                             onclick="document.getElementById('mainImgTag').src=this.src; document.querySelectorAll('.gallery-thumbs img').forEach(i=>i.classList.remove('active')); this.classList.add('active');"
                                             class="@(img == images.First() ? "active" : "")" />
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- Product Info -->
                    <div class="col-lg-6">
                        <div class="product-info">
                            @if (!string.IsNullOrEmpty(p.CategoryName))
                            {
                                <span class="product-category-badge">@p.CategoryName</span>
                            }

                            <h1 class="product-detail-title">@p.Title</h1>

                            <!-- Rating Summary -->
                            <div class="rating-summary">
                                <span class="stars">
                                    @{
                                        int fullStars = (int)p.AverageRating;
                                        bool halfStar = (p.AverageRating - fullStars) >= 0.5;
                                    }
                                    @for (int i = 0; i < fullStars; i++) { <text>★</text> }
                                    @if (halfStar) { <text>★</text> }
                                    @for (int i = fullStars + (halfStar ? 1 : 0); i < 5; i++) { <text>☆</text> }
                                </span>
                                <span class="rating-text">
                                    <strong>@p.AverageRating</strong>/5
                                    (@p.ReviewCount review@(p.ReviewCount != 1 ? "s" : ""))
                                </span>
                            </div>

                            <!-- Price -->
                            <div class="price-section">
                                <div class="price-label">Price</div>
                                <div class="price-value">$@(p.Price?.ToString("N2") ?? "0.00")</div>
                                @if (p.IsAuction == true)
                                {
                                    <div class="auction-badge-detail">
                                        <span class="timer-icon">⏱️</span>
                                        Auction
                                        @if (p.AuctionEndTime.HasValue)
                                        {
                                            <span>· Ends @p.AuctionEndTime.Value.ToString("MMM dd, yyyy HH:mm")</span>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Stock -->
                            <div class="stock-info">
                                @if (p.StockQuantity > 10)
                                {
                                    <span class="stock-badge in-stock">✓ In Stock</span>
                                    <span class="text-muted">@p.StockQuantity available</span>
                                }
                                else if (p.StockQuantity > 0)
                                {
                                    <span class="stock-badge low-stock">⚠ Low Stock</span>
                                    <span class="text-muted">Only @p.StockQuantity left!</span>
                                }
                                else
                                {
                                    <span class="stock-badge out-of-stock">✕ Out of Stock</span>
                                }
                            </div>
                            
                                <div class="action-buttons my-4">
                                    <button class="btn btn-lg btn-danger px-5" style="background: linear-gradient(135deg, #e94560, #c0392b); border: none; border-radius: 10px; font-weight: bold;"
                                    onclick="addToCart(@p.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Title))', @(p.Price?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? "0"), '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(p.Images?.Split(',').FirstOrDefault() ?? ""))')">
                                        🛒 Add to Cart
                                    </button>
                                </div>

                            <!-- Description -->
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="product-description-section">
                                    <h5>📋 Description</h5>
                                    <div class="product-description-text">@p.Description</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <!-- ═══ Reviews Section ═══ -->
                <div class="reviews-section">
                    <h4>⭐ Customer Reviews</h4>

                    @if (p.ReviewCount > 0)
                    {
                        <!-- Review Summary -->
                        <div class="review-summary">
                            <div class="review-avg">
                                <div class="review-avg-number">@p.AverageRating</div>
                                <div class="review-avg-stars">
                                    @for (int i = 0; i < fullStars; i++) { <text>★</text> }
                                    @if (halfStar) { <text>★</text> }
                                    @for (int i = fullStars + (halfStar ? 1 : 0); i < 5; i++) { <text>☆</text> }
                                </div>
                                <div class="review-avg-count">@p.ReviewCount review@(p.ReviewCount != 1 ? "s" : "")</div>
                            </div>
                            <div>
                                @{
                                    var ratingGroups = p.Reviews
                                        .Where(r => r.Rating.HasValue)
                                        .GroupBy(r => r.Rating!.Value)
                                        .ToDictionary(g => g.Key, g => g.Count());
                                }
                                @for (int star = 5; star >= 1; star--)
                                {
                                    var count = ratingGroups.ContainsKey(star) ? ratingGroups[star] : 0;
                                    var pct = p.ReviewCount > 0 ? (count * 100.0 / p.ReviewCount) : 0;
                                    <div class="d-flex align-items-center gap-2 mb-1" style="min-width: 280px;">
                                        <span style="font-size: 0.8rem; color: #6c757d; width: 50px;">@star star@(star != 1 ? "s" : "")</span>
                                        <div style="flex: 1; height: 8px; background: #e9ecef; border-radius: 4px; overflow: hidden;">
                                            <div style="width: @pct%; height: 100%; background: #f39c12; border-radius: 4px;"></div>
                                        </div>
                                        <span style="font-size: 0.8rem; color: #6c757d; width: 25px; text-align: right;">@count</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Review List -->
                        @foreach (var review in p.Reviews)
                        {
                            <div class="review-item">
                                <div class="review-header">
                                    @if (!string.IsNullOrEmpty(review.ReviewerAvatar))
                                    {
                                        <img src="@review.ReviewerAvatar" alt="@review.ReviewerName" class="review-avatar" />
                                    }
                                    else
                                    {
                                        <div class="review-avatar-placeholder">
                                            @(review.ReviewerName?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                    }
                                    <div>
                                        <div class="review-author">@(review.ReviewerName ?? "Anonymous")</div>
                                        <div class="review-date">
                                            @(review.CreatedAt?.ToString("MMM dd, yyyy") ?? "")
                                        </div>
                                    </div>
                                </div>
                                <div class="review-stars">
                                    @if (review.Rating.HasValue)
                                    {
                                        @for (int i = 0; i < review.Rating.Value; i++) { <text>★</text> }
                                        @for (int i = review.Rating.Value; i < 5; i++) { <text>☆</text> }
                                    }
                                </div>
                                <div class="review-comment">@review.Comment</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-reviews">
                            <div class="no-icon">💬</div>
                            <h5>No reviews yet</h5>
                            <p class="text-muted">Be the first to review this product!</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <!-- ═══ Seller Info ═══ -->
                @if (p.Seller != null)
                {
                    <div class="seller-card">
                        <h4>🏪 Seller Information</h4>
                        <div class="seller-profile">
                            @if (!string.IsNullOrEmpty(p.Seller.AvatarUrl))
                            {
                                <img src="@p.Seller.AvatarUrl" alt="@p.Seller.Username" class="seller-avatar" />
                            }
                            else
                            {
                                <div class="seller-avatar-placeholder">
                                    @(p.Seller.Username?.Substring(0, 1).ToUpper() ?? "S")
                                </div>
                            }
                            <div>
                                <div class="seller-name">@p.Seller.Username</div>
                                @if (!string.IsNullOrEmpty(p.Seller.StoreName))
                                {
                                    <div class="seller-store">🏬 @p.Seller.StoreName</div>
                                }
                            </div>
                        </div>

                        <div class="seller-stats">
                            <div class="seller-stat">
                                <div class="seller-stat-value" style="color: #f39c12;">
                                    @(p.Seller.AverageRating?.ToString("F1") ?? "N/A")
                                </div>
                                <div class="seller-stat-label">Rating</div>
                            </div>
                            <div class="seller-stat">
                                <div class="seller-stat-value">
                                    @(p.Seller.PositiveRate.HasValue ? p.Seller.PositiveRate.Value.ToString("F0") + "%" : "N/A")
                                </div>
                                <div class="seller-stat-label">Positive</div>
                            </div>
                            <div class="seller-stat">
                                <div class="seller-stat-value">@p.Seller.TotalProducts</div>
                                <div class="seller-stat-label">Products</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(p.Seller.StoreDescription))
                        {
                            <p class="mt-3 mb-0" style="font-size: 0.85rem; color: #6c757d; line-height: 1.6;">
                                @p.Seller.StoreDescription
                            </p>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ═══ Related Products ═══ -->
        @if (p.RelatedProducts.Any())
        {
            <div class="related-section">
                <h4>🔗 Related Products</h4>
                <div class="row g-4">
                    @foreach (var rp in p.RelatedProducts)
                    {
                        <div class="col-6 col-md-3">
                            <a asp-page="/ProductDetail" asp-route-id="@rp.Id" class="related-card">
                                <div class="related-card-img">
                                    @if (!string.IsNullOrEmpty(rp.Images))
                                    {
                                        var firstImg = rp.Images.Split(',')[0].Trim();
                                        <img src="@firstImg" alt="@rp.Title"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                                        <div class="r-placeholder" style="display:none;">📦</div>
                                    }
                                    else
                                    {
                                        <div class="r-placeholder">📦</div>
                                    }
                                </div>
                                <div class="related-card-body">
                                    <div class="related-card-title">@rp.Title</div>
                                    <div class="related-card-price">$@(rp.Price?.ToString("N2") ?? "0.00")</div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
