@page
@model PRN232_Ebay_Buyer.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-5">
    <h2 class="mb-4">💳 Checkout</h2>
    <div class="row">
        <!-- Addresses & Payment -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0">Delivery Address</h5>
                </div>
                <div class="card-body">
                    @if(Model.Addresses.Any()) {
                        <div class="row" id="addressContainer">
                            @foreach(var address in Model.Addresses.OrderByDescending(a => a.IsDefault)) {
                                <div class="col-md-6 mb-3">
                                    <div class="card bg-light border @(address.IsDefault ? "border-primary" : "") pointer addr-card" onclick="selectAddress(@address.Id, this)" style="cursor: pointer;">
                                        <div class="card-body position-relative">
                                            @if(address.IsDefault) {
                                                <span class="badge bg-primary position-absolute top-0 end-0 m-2">Default</span>
                                            }
                                            <h6 class="card-title">@address.FullName</h6>
                                            <p class="card-text mb-1"><small class="text-muted">📞 @address.Phone</small></p>
                                            <p class="card-text mb-0"><small>@address.Street, @address.City, @address.State, @address.Country</small></p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    } else {
                        <div class="alert alert-warning">Please add an address first.</div>
                    }

                    <div class="mt-4">
                        <h6>➕ Add New Address</h6>
                        <form id="newAddressForm" onsubmit="addAddress(event)">
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <input type="text" id="FullName" class="form-control" placeholder="Full Name" required>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <input type="text" id="Phone" class="form-control" placeholder="Phone" required>
                                </div>
                                <div class="col-12 mb-2">
                                    <input type="text" id="Street" class="form-control" placeholder="Street Address" required>
                                </div>
                                <div class="col-md-4 mb-2">
                                    <input type="text" id="City" class="form-control" placeholder="City" required>
                                </div>
                                <div class="col-md-4 mb-2">
                                    <input type="text" id="State" class="form-control" placeholder="State" required>
                                </div>
                                <div class="col-md-4 mb-2">
                                    <input type="text" id="Country" class="form-control" placeholder="Country" required>
                                </div>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="IsDefault">
                                <label class="form-check-label" for="IsDefault">Set as default</label>
                            </div>
                            <button type="submit" class="btn btn-secondary btn-sm">Save Address</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0">Payment Method</h5>
                </div>
                <div class="card-body">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="paymentMethod" id="payCOD" value="COD" checked>
                        <label class="form-check-label fw-bold" for="payCOD">
                            💵 Cash on Delivery (COD)
                        </label>
                        <p class="text-muted small mt-1">Due to system limits, currently only COD is available.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h5 class="card-title mb-4">Order Summary</h5>
                    <div id="checkoutItems" class="mb-3"></div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <strong>Total</strong>
                        <h4 class="text-danger mb-0" id="checkoutTotal">$0.00</h4>
                    </div>
                    <button class="btn btn-danger w-100 py-3" style="font-weight: bold; border-radius: 10px;" onclick="placeOrder()">
                        Place Order
                    </button>
                    <div id="checkoutError" class="text-danger mt-2 small text-center"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedAddressId = @(Model.Addresses.FirstOrDefault(a => a.IsDefault)?.Id ?? Model.Addresses.FirstOrDefault()?.Id ?? 0);
        let jwtToken = document.cookie.match(new RegExp('(^| )BearerToken=([^;]+)'))?.[2];

        document.addEventListener('DOMContentLoaded', () => {
            renderCheckoutCart();
        });

        function selectAddress(id, element) {
            selectedAddressId = id;
            document.querySelectorAll('.addr-card').forEach(c => c.classList.remove('border-primary', 'border-2'));
            element.classList.add('border-primary', 'border-2');
        }

        function renderCheckoutCart() {
            let cart = getCart();
            if(cart.length === 0) {
                window.location = "/Cart";
                return;
            }

            let html = '';
            let total = 0;
            cart.forEach(item => {
                let itemTotal = item.price * item.quantity;
                total += itemTotal;
                html += `
                    <div class="d-flex justify-content-between mb-2">
                        <span>${item.quantity}x ${item.title.substring(0, 20)}...</span>
                        <span>$${itemTotal.toFixed(2)}</span>
                    </div>
                `;
            });
            document.getElementById('checkoutItems').innerHTML = html;
            document.getElementById('checkoutTotal').innerText = '$' + total.toFixed(2);
        }

        function getFormData() {
            return {
                FullName: document.getElementById('FullName').value,
                Phone: document.getElementById('Phone').value,
                Street: document.getElementById('Street').value,
                City: document.getElementById('City').value,
                State: document.getElementById('State').value,
                Country: document.getElementById('Country').value,
                IsDefault: document.getElementById('IsDefault').checked
            };
        }

        async function addAddress(e) {
            e.preventDefault();
            if(!jwtToken) return alert("Please login.");

            let data = getFormData();
            try {
                let r = await fetch('http://localhost:5001/api/Order/address', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwtToken },
                    body: JSON.stringify(data)
                });
                let res = await r.json();
                if(res.success) {
                    window.location.reload();
                } else {
                    alert(res.message);
                }
            } catch(er) { console.error(er); }
        }

        async function placeOrder() {
            if(!jwtToken) {
                alert("You need to be logged in.");
                return window.location = "/Auth/Login";
            }
            if(selectedAddressId <= 0) {
                document.getElementById('checkoutError').innerText = "Please select or add a delivery address.";
                return;
            }

            let cart = getCart();
            if(cart.length === 0) return alert("Cart is empty.");

            let payload = {
                AddressId: selectedAddressId,
                PaymentMethod: "COD",
                Items: cart
            };

            document.getElementById('checkoutError').innerText = "Processing...";

            try {
                let r = await fetch('http://localhost:5001/api/Order/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwtToken },
                    body: JSON.stringify(payload)
                });
                let res = await r.json();
                if(res.success) {
                    alert("Order placed successfully!");
                    saveCart([]); // clear cart
                    window.location = "/Profile";
                } else {
                    document.getElementById('checkoutError').innerText = res.message;
                }
            } catch(e) {
                console.error(e);
                document.getElementById('checkoutError').innerText = "Failed to communicate with server.";
            }
        }
    </script>
}
