@page
@model PRN232_Ebay_Buyer.Pages.OrdersModel
@{
    ViewData["Title"] = "My Orders";
    var statuses = new[] { "All", "Pending", "Processing", "Shipped", "Delivered", "Cancelled" };
    var pagedData  = Model.OrdersData;
    var curPage    = pagedData?.PageNumber ?? 1;
    var totalPages = pagedData?.TotalPages ?? 1;
}

<style>
    .orders-page { max-width: 900px; margin: 0 auto; }

    /* ── Header ── */
    .page-header {
        margin-bottom: 28px;
    }
    .page-header h1 {
        font-size: 1.8rem; font-weight: 800;
        color: #1a1a2e; margin-bottom: 4px;
    }
    .page-header p { color: #6c757d; font-size: 0.95rem; }

    /* ── Status Filter Tabs ── */
    .status-tabs {
        display: flex; gap: 6px; flex-wrap: wrap;
        margin-bottom: 24px;
        background: white; padding: 6px;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
    }
    .status-tab {
        padding: 8px 18px; border-radius: 10px;
        font-size: 0.85rem; font-weight: 600;
        text-decoration: none; color: #6c757d;
        transition: all 0.2s; border: none;
        background: transparent; cursor: pointer;
    }
    .status-tab:hover { background: #f0f2f5; color: #1a1a2e; }
    .status-tab.active { background: #e94560; color: white; }

    /* ── Order Card ── */
    .order-card {
        background: white; border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
        margin-bottom: 16px;
        transition: all 0.25s;
        overflow: hidden;
    }
    .order-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        border-color: #e94560;
    }
    .order-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #f0f2f5;
        display: flex; align-items: center;
        justify-content: space-between; flex-wrap: wrap; gap: 8px;
    }
    .order-id {
        font-weight: 700; color: #1a1a2e; font-size: 1rem;
    }
    .order-date { font-size: 0.82rem; color: #adb5bd; }

    .status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 20px;
        font-size: 0.8rem; font-weight: 700;
    }

    .order-card-body { padding: 16px 20px; }
    .order-meta {
        display: flex; align-items: center; gap: 24px;
        flex-wrap: wrap;
    }
    .order-meta-item { display: flex; flex-direction: column; }
    .order-meta-label { font-size: 0.75rem; color: #adb5bd; margin-bottom: 2px; }
    .order-meta-value { font-size: 0.95rem; font-weight: 600; color: #1a1a2e; }
    .order-meta-value.price { color: #e94560; font-size: 1.1rem; }

    .order-card-footer {
        padding: 12px 20px;
        background: #fafbfc;
        border-top: 1px solid #f0f2f5;
        display: flex; justify-content: flex-end; gap: 8px;
    }

    /* ── Buttons ── */
    .btn-detail {
        padding: 8px 20px; border-radius: 10px;
        background: linear-gradient(135deg, #e94560, #c0392b);
        color: white; font-weight: 600; font-size: 0.85rem;
        text-decoration: none; border: none;
        transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-detail:hover {
        color: white; transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(233,69,96,0.35);
    }

    /* ── Empty State ── */
    .empty-state {
        text-align: center; padding: 60px 20px;
        background: white; border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf1;
    }
    .empty-icon { font-size: 4rem; color: #dee2e6; margin-bottom: 16px; }
    .empty-state h4 { color: #495057; margin-bottom: 8px; font-weight: 700; }
    .empty-state p { color: #adb5bd; margin-bottom: 24px; }

    /* ── Alert ── */
    .alert-custom {
        padding: 14px 20px; border-radius: 12px;
        margin-bottom: 20px; font-size: 0.9rem; font-weight: 500;
        display: flex; align-items: center; gap: 10px;
    }
    .alert-error { background: #fdf0f2; border: 1px solid #fbd0d8; color: #c0392b; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }

    /* ── Pagination ── */
    .pagination-wrapper {
        display: flex; justify-content: center; gap: 6px;
        margin-top: 28px;
    }
    .page-btn {
        width: 38px; height: 38px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem; font-weight: 600; text-decoration: none;
        background: white; color: #6c757d;
        border: 1px solid #e8ecf1; transition: all 0.2s;
    }
    .page-btn:hover { border-color: #e94560; color: #e94560; }
    .page-btn.active { background: #e94560; color: white; border-color: #e94560; }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .order-card { animation: fadeIn 0.4s ease both; }
    .order-card:nth-child(1) { animation-delay: 0s; }
    .order-card:nth-child(2) { animation-delay: 0.05s; }
    .order-card:nth-child(3) { animation-delay: 0.1s; }
    .order-card:nth-child(4) { animation-delay: 0.15s; }
    .order-card:nth-child(5) { animation-delay: 0.2s; }
</style>

<div class="orders-page">

    <!-- ═══ Header ═══ -->
    <div class="page-header">
        <h1>📦 Đơn Hàng Của Tôi</h1>
        <p>Theo dõi trạng thái và lịch sử mua sắm của bạn</p>
    </div>

    <!-- ═══ Alert ═══ -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-custom alert-error">⚠️ @Model.ErrorMessage</div>
    }

    <!-- ═══ Status Tabs ═══ -->
    <div class="status-tabs">
        @foreach (var s in statuses)
        {
            var isActive = (string.IsNullOrEmpty(Model.StatusFilter) && s == "All")
                        || Model.StatusFilter == s;
            <a href="?StatusFilter=@(s == "All" ? "" : s)&CurrentPage=1"
               class="status-tab @(isActive ? "active" : "")">
                @s
            </a>
        }
    </div>

    <!-- ═══ Order List ═══ -->
    @if (Model.OrdersData?.Items is { Count: > 0 } orders)
    {
        @foreach (var order in orders)
        {
            var style = Model.GetStatusStyle(order.Status);
            <div class="order-card">
                <div class="order-card-header">
                    <div>
                        <div class="order-id">Đơn hàng #@order.Id</div>
                        <div class="order-date">
                            📅 @(order.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                        </div>
                    </div>
                    <span class="status-badge"
                          style="background:@style.Bg; color:@style.Text;">
                        @style.Icon @order.Status
                    </span>
                </div>

                <div class="order-card-body">
                    <div class="order-meta">
                        <div class="order-meta-item">
                            <span class="order-meta-label">Số sản phẩm</span>
                            <span class="order-meta-value">@order.ItemCount sản phẩm</span>
                        </div>
                        <div class="order-meta-item">
                            <span class="order-meta-label">Tổng tiền</span>
                            <span class="order-meta-value price">
                                $@(order.TotalPrice?.ToString("N2") ?? "0.00")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="order-card-footer">
                    <a asp-page="/OrderDetail" asp-route-id="@order.Id" class="btn-detail">
                        Xem chi tiết →
                    </a>
                </div>
            </div>
        }
        @if (totalPages > 1)
        {
            <div class="pagination-wrapper">
                <a href="?StatusFilter=@Model.StatusFilter&CurrentPage=@(curPage - 1)"
                   class="page-btn @(pagedData!.HasPreviousPage ? "" : "disabled")">&#8249;</a>

                @for (int p = 1; p <= totalPages; p++)
                {
                    <a href="?StatusFilter=@Model.StatusFilter&CurrentPage=@p"
                       class="page-btn @(p == curPage ? "active" : "")">@p</a>
                }

                <a href="?StatusFilter=@Model.StatusFilter&CurrentPage=@(curPage + 1)"
                   class="page-btn @(pagedData.HasNextPage ? "" : "disabled")">&#8250;</a>
            </div>
        }
    }
    else if (Model.OrdersData != null)
    {
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h4>Không có đơn hàng nào</h4>
            <p>@(string.IsNullOrEmpty(Model.StatusFilter) || Model.StatusFilter == "All"
                ? "Bạn chưa đặt hàng nào. Hãy bắt đầu mua sắm!"
                : $"Không có đơn hàng nào ở trạng thái \"{Model.StatusFilter}\".")</p>
            <a asp-page="/Products"
               style="display:inline-block; padding:10px 28px; border-radius:10px;
                      background:linear-gradient(135deg,#e94560,#c0392b);
                      color:white; font-weight:600; text-decoration:none;">
                🛍️ Mua sắm ngay
            </a>
        </div>
    }

</div>
