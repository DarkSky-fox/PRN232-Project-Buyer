@page
@model CartModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">
    <h2 class="mb-4">🛒 Shopping Cart</h2>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <table class="table table-borderless align-middle" id="cartTable">
                        <thead class="border-bottom text-muted">
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="cartBody">
                            <!-- Items will be rendered here by JS -->
                        </tbody>
                    </table>
                    <div id="emptyCart" class="text-center py-5" style="display: none;">
                        <h4 class="text-muted">Your cart is empty</h4>
                        <a href="/Products" class="btn btn-outline-danger mt-3">Continue Shopping</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h5 class="card-title mb-4">Order Summary</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Subtotal</span>
                        <h5 class="mb-0" id="cartSubtotal">$0.00</h5>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <strong>Total</strong>
                        <h4 class="text-danger mb-0" id="cartTotal">$0.00</h4>
                    </div>
                    <a href="/Checkout" class="btn btn-danger w-100 py-2" style="font-weight: 600; border-radius: 10px;" id="checkoutBtn">
                        Proceed to Checkout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function renderCart() {
            let cart = getCart();
            let tbody = document.getElementById('cartBody');
            let emptyCart = document.getElementById('emptyCart');
            let cartTable = document.getElementById('cartTable');
            let btn = document.getElementById('checkoutBtn');

            if(cart.length === 0) {
                emptyCart.style.display = 'block';
                cartTable.style.display = 'none';
                btn.style.display = 'none';
                document.getElementById('cartSubtotal').innerText = '$0.00';
                document.getElementById('cartTotal').innerText = '$0.00';
                return;
            }

            emptyCart.style.display = 'none';
            cartTable.style.display = 'table';
            btn.style.display = 'block';

            let html = '';
            let total = 0;
            cart.forEach((item, index) => {
                let itemTotal = item.price * item.quantity;
                total += itemTotal;
                html += `
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="${item.imageUrl}" alt="${item.title}" class="rounded me-3" style="width: 64px; height: 64px; object-fit: cover;">
                                <div>
                                    <h6 class="mb-0">${item.title}</h6>
                                </div>
                            </div>
                        </td>
                        <td>$${item.price.toFixed(2)}</td>
                        <td>
                            <div class="input-group" style="width: 120px;">
                                <button class="btn btn-outline-secondary" type="button" onclick="updateQty(${item.productId}, -1)">-</button>
                                <input type="text" class="form-control text-center" value="${item.quantity}" readonly>
                                <button class="btn btn-outline-secondary" type="button" onclick="updateQty(${item.productId}, 1)">+</button>
                            </div>
                        </td>
                        <td class="fw-bold">$${itemTotal.toFixed(2)}</td>
                        <td>
                            <button class="btn btn-sm btn-light text-danger" onclick="removeItem(${item.productId})">
                                🗑️
                            </button>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
            document.getElementById('cartSubtotal').innerText = '$' + total.toFixed(2);
            document.getElementById('cartTotal').innerText = '$' + total.toFixed(2);
        }

        function updateQty(id, change) {
            let cart = getCart();
            let item = cart.find(i => i.productId === id);
            if(item) {
                item.quantity += change;
                if(item.quantity <= 0) {
                    cart = cart.filter(i => i.productId !== id);
                }
                saveCart(cart);
                renderCart();
            }
        }

        function removeItem(id) {
            let cart = getCart();
            cart = cart.filter(i => i.productId !== id);
            saveCart(cart);
            renderCart();
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderCart();
        });
    </script>
}
